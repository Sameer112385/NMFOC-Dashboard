{
  "pages": {
    "/global-error": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/global-error.js"
    ],
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/page.js"
    ],
    "/(auth)/login/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(auth)/login/page.js"
    ],
    "/api/settings/supabase/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/settings/supabase/route.js"
    ],
    "/(app)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/layout.js"
    ],
    "/(app)/error": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/error.js"
    ],
    "/(app)/projects/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/projects/page.js"
    ],
    "/(app)/projects/[projectId]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/projects/[projectId]/page.js"
    ],
    "/api/financial-sources/recalculate/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/financial-sources/recalculate/route.js"
    ]
  }
}